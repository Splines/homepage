{
  "compilerOptions": {
      "target": "esnext",
      "module": "esnext",
      "lib": [
          "ESNext",
          "DOM"
      ],
      "moduleResolution": "bundler",
      "isolatedModules": true,
      "useDefineForClassFields": true,
      "strict": true,
      "strictNullChecks": true,
      "sourceMap": true,
      "resolveJsonModule": true,
      "noEmit": true,
      "noUnusedLocals": true,
      "noUnusedParameters": true,
      "noImplicitReturns": true,
      "allowJs": true,
      "checkJs": true,
  },
  "include": [
      "assets/vite/**/*.js",
      "assets/vite/**/*.ts",
  ],
}